# PostgreSQL Database Configuration
DB_USER=tafa_admin
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION_USE_VAULT
DB_NAME=tafa_production
DB_PORT=5434
DB_REPLICA_PORT=5435

# Redis Configuration
REDIS_PASSWORD=CHANGE_ME_IN_PRODUCTION_USE_VAULT
REDIS_PORT=6380

# PgAdmin Configuration (dev/staging only)
