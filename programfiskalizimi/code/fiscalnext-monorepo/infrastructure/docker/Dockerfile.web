# FiscalNext Web Apps Dockerfile (Next.js)
# Multi-stage build for production optimization
# Created by: Max (DevOps)

# Development Stage
FROM node:20-alpine AS development

ARG APP_NAME
WORKDIR /app

# Install dependencies for native modules
RUN apk add --no-cache libc6-compat

# Copy package files
COPY package.json package-lock.json* turbo.json ./
COPY apps/${APP_NAME}/package.json ./apps/${APP_NAME}/
COPY packages/*/package.json ./packages/*/

# Install dependencies
RUN npm install

# Copy source code
COPY . .

ENV NEXT_TELEMETRY_DISABLED 1

EXPOSE 3000

CMD ["sh", "-c", "npm run dev --workspace=@fiscalnext/${APP_NAME}"]

# Dependencies Stage
FROM node:20-alpine AS deps

ARG APP_NAME
WORKDIR /app

# Install dependencies for native modules
RUN apk add --no-cache libc6-compat

# Copy package files
COPY package.json package-lock.json* turbo.json ./
COPY apps/${APP_NAME}/package.json ./apps/${APP_NAME}/
COPY packages/*/package.json ./packages/*/

# Install dependencies
RUN npm ci

# Build Stage
FROM node:20-alpine AS builder

ARG APP_NAME
WORKDIR /app

# Copy dependencies
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/${APP_NAME}/node_modules ./apps/${APP_NAME}/node_modules

# Copy source code
COPY . .

# Disable telemetry
ENV NEXT_TELEMETRY_DISABLED 1

# Build the application
RUN npm run build --workspace=@fiscalnext/${APP_NAME}

# Production Stage
FROM node:20-alpine AS production

ARG APP_NAME
WORKDIR /app

ENV NODE_ENV production
ENV NEXT_TELEMETRY_DISABLED 1

# Create non-root user
RUN addgroup -g 1001 -S nodejs && \
    adduser -S nextjs -u 1001

# Copy built application
COPY --from=builder /app/apps/${APP_NAME}/public ./public
COPY --from=builder --chown=nextjs:nodejs /app/apps/${APP_NAME}/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/${APP_NAME}/.next/static ./apps/${APP_NAME}/.next/static

# Switch to non-root user
USER nextjs

EXPOSE 3000

ENV PORT 3000

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=40s --retries=3 \
  CMD node -e "require('http').get('http://localhost:3000/api/health', (r) => {process.exit(r.statusCode === 200 ? 0 : 1)})"

CMD ["node", "apps/${APP_NAME}/server.js"]
