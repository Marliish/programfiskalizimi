// ============================================
// 3. STOCK FORECASTING (10 features)
// ============================================

model DemandForecast {
  id        String @id @default(uuid())
  tenantId  String @map("tenant_id")
  productId String @map("product_id")

  // Forecast period
  forecastDate DateTime @map("forecast_date")
  periodType   String   @default("daily") @map("period_type") // daily, weekly, monthly

  // Forecast values
  predictedDemand Decimal @map("predicted_demand") @db.Decimal(10, 2)
  confidenceLevel Decimal @map("confidence_level") @db.Decimal(5, 2) // 0-100
  lowerBound      Decimal @map("lower_bound") @db.Decimal(10, 2)
  upperBound      Decimal @map("upper_bound") @db.Decimal(10, 2)

  // Actuals (for accuracy tracking)
  actualDemand Decimal? @map("actual_demand") @db.Decimal(10, 2)
  accuracy     Decimal? @db.Decimal(5, 2)

  // Factors
  seasonalityFactor Decimal? @map("seasonality_factor") @db.Decimal(10, 4)
  trendFactor       Decimal? @map("trend_factor") @db.Decimal(10, 4)

  // Model info
  modelVersion  String? @map("model_version")
  algorithmUsed String? @map("algorithm_used") // moving_average, exponential_smoothing, arima, ml

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([tenantId, productId, forecastDate])
  @@index([tenantId])
  @@index([productId])
  @@index([forecastDate])
  @@map("demand_forecasts")
}

model SeasonalPattern {
  id         String  @id @default(uuid())
  tenantId   String  @map("tenant_id")
  productId  String? @map("product_id")
  categoryId String? @map("category_id")

  patternName String @map("pattern_name")
  patternType String @map("pattern_type") // daily, weekly, monthly, yearly, holiday

  // Pattern data (JSON array of multipliers)
  multipliers Json @default("[]") // e.g., [1.2, 1.5, 0.8, ...] for each period

  // Date ranges
  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")

  // Statistics
  averageMultiplier Decimal @default(1.0) @map("average_multiplier") @db.Decimal(10, 4)
  peakMultiplier    Decimal @default(1.0) @map("peak_multiplier") @db.Decimal(10, 4)
