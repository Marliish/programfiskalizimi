  refereeRewardAmount Decimal @map("referee_reward_amount") @db.Decimal(10, 2)

  // Conditions
  minPurchaseAmount Decimal @default(0) @map("min_purchase_amount") @db.Decimal(10, 2)

  // Status
  isActive Boolean   @default(true) @map("is_active")
  startsAt DateTime? @map("starts_at")
  endsAt   DateTime? @map("ends_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  referrals Referral[]

  @@index([tenantId])
  @@map("referral_programs")
}

model Referral {
  id        String @id @default(uuid())
  programId String @map("program_id")

  // Referrer (customer making the referral)
  referrerCustomerId String @map("referrer_customer_id")

  // Referee (new customer)
  refereeCustomerId String? @map("referee_customer_id")

  referralCode String @unique @map("referral_code")

  // Tracking
  clicks Int    @default(0)
  status String @default("pending") // pending, completed, expired

  // Completion
  completedAt    DateTime? @map("completed_at")
  purchaseAmount Decimal?  @map("purchase_amount") @db.Decimal(10, 2)

  // Rewards
  referrerRewardGiven Boolean @default(false) @map("referrer_reward_given")
  refereeRewardGiven  Boolean @default(false) @map("referee_reward_given")

  createdAt DateTime  @default(now()) @map("created_at")
  expiresAt DateTime? @map("expires_at")

  // Relations
  program          ReferralProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  referrerCustomer Customer        @relation("CustomerReferrals", fields: [referrerCustomerId], references: [id], onDelete: Cascade)
  refereeCustomer  Customer?       @relation("CustomerReferees", fields: [refereeCustomerId], references: [id], onDelete: SetNull)

  @@index([programId])
  @@index([referrerCustomerId])
  @@index([referralCode])
  @@map("referrals")
}

// ============================================
// SOCIAL MEDIA
// ============================================

model SocialPost {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  platform String // facebook, instagram, twitter
  content  String @db.Text

  // Media (JSON array of URLs)
  mediaUrls Json @default("[]") @map("media_urls")

  // Status
  status String @default("draft") // draft, scheduled, published, failed

  // Scheduling
  scheduledFor DateTime? @map("scheduled_for")
  publishedAt  DateTime? @map("published_at")

  // External IDs
  platformPostId String? @map("platform_post_id")

  // Stats
  likes          Int     @default(0)
  shares         Int     @default(0)
  comments       Int     @default(0)
  impressions    Int     @default(0)
  engagementRate Decimal @default(0) @map("engagement_rate") @db.Decimal(5, 2)

  errorMessage String? @map("error_message") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([platform])
  @@index([status])
  @@index([scheduledFor])
  @@map("social_posts")
}

model SocialReview {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  platform String // google, facebook, yelp

  reviewerName       String? @map("reviewer_name")
  reviewerProfileUrl String? @map("reviewer_profile_url")

  rating     Int     @map("rating") // 1-5
  reviewText String? @map("review_text") @db.Text

  // Response
  responded    Boolean   @default(false)
  responseText String?   @map("response_text") @db.Text
  respondedAt  DateTime? @map("responded_at")

  // Metadata
  reviewDate       DateTime? @map("review_date")
  platformReviewId String?   @map("platform_review_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([platform])
  @@index([rating])
  @@index([responded])
  @@map("social_reviews")
}

model SocialAccount {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  platform      String // facebook, instagram, twitter
  accountName   String? @map("account_name")
  accountHandle String? @map("account_handle")

  // OAuth tokens (encrypted)
  accessTokenEncrypted  String?   @map("access_token_encrypted") @db.Text
  refreshTokenEncrypted String?   @map("refresh_token_encrypted") @db.Text
  tokenExpiresAt        DateTime? @map("token_expires_at")

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, platform])
  @@index([tenantId])
  @@map("social_accounts")
}

