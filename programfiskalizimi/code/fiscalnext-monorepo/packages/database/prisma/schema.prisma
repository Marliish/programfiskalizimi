model Warehouse {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  name    String
  code    String  @unique
  address String?
  city    String?
  country String  @default("AL")

  // Configuration
  type     String  @default("warehouse") // warehouse, distribution_center, retail
  isActive Boolean @default(true) @map("is_active")

  // Capacity
  totalArea     Decimal? @map("total_area") @db.Decimal(10, 2) // in square meters
  usedArea      Decimal? @default(0) @map("used_area") @db.Decimal(10, 2)
  capacityUnits Int?     @default(0) @map("capacity_units")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  zones           WarehouseZone[]
  bins            WarehouseBin[]
