generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                      String                   @id @default(uuid())
  name                    String
  slug                    String                   @unique
  businessType            String?                  @map("business_type")
  nipt                    String?
  address                 String?
  city                    String?
  country                 String                   @default("AL")
  phone                   String?
  email                   String?
  logoUrl                 String?                  @map("logo_url")
  subscriptionPlan        String?                  @default("trial") @map("subscription_plan")
  subscriptionStatus      String?                  @default("active") @map("subscription_status")
  trialEndsAt             DateTime?                @map("trial_ends_at")
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")
  settings                Json?                    @default("{}")
  abandonedCartRecoveries AbandonedCartRecovery[]
  analyticsCache          AnalyticsCache[]
  automationWorkflows     AutomationWorkflow[]
  bankAccounts            BankAccount[]
  bankReconciliations     BankReconciliation[]
  bills                   Bill[]
  BOM                     BOM[]
  BOMItem                 BOMItem[]
  BOMSubstitution         BOMSubstitution[]
  BOMVersion              BOMVersion[]
  BottleneckAnalysis      BottleneckAnalysis[]
  categories              Category[]
  cannedResponses         ChatCannedResponse[]
  chatConversations       ChatConversation[]
  CorrectiveAction        CorrectiveAction[]
  customerSegments        CustomerSegment[]
  customers               Customer[]
  DefectTracking          DefectTracking[]
  emailCampaigns          EmailCampaign[]
  emailTemplates          EmailTemplate[]
  employeeDocuments       EmployeeDocument[]
  employees               Employee[]
  expenseCategories       ExpenseCategory[]
  expenses                Expense[]
  fiscalReceipts          FiscalReceipt[]
  InspectionPlan          InspectionPlan[]
  LaborTracking           LaborTracking[]
  locations               Location[]
  MachineSchedule         MachineSchedule[]
  MachineTimeTracking     MachineTimeTracking[]
  MaterialRequirement     MaterialRequirement[]
  onboardingChecklists    OnboardingChecklist[]
  payrollRuns             PayrollRun[]
  performanceReviews      PerformanceReview[]
  productRecommendations  ProductRecommendation[]
  productReviews          ProductReview[]
  productViews            ProductView[]
  ProductionCalendar      ProductionCalendar[]
  ProductionCostAnalysis  ProductionCostAnalysis[]
  ProductionCostRecord    ProductionCostRecord[]
  ProductionForecast      ProductionForecast[]
  ProductionMachine       ProductionMachine[]
  ProductionSchedule      ProductionSchedule[]
  ProductionShift         ProductionShift[]
  products                Product[]
  QCCheckpoint            QCCheckpoint[]
  QCReport                QCReport[]
  referralPrograms        ReferralProgram[]
  ResourceAllocation      ResourceAllocation[]
  roles                   Role[]
  savedCarts              SavedCart[]
  ScrapRecord             ScrapRecord[]
  seoImageOptimizations   SeoImageOptimization[]
  seoMetadata             SeoMetadata[]
  seoRedirects            SeoRedirect[]
  smsCampaigns            SmsCampaign[]
  socialAccounts          SocialAccount[]
  socialPosts             SocialPost[]
  socialReviews           SocialReview[]
  stock                   Stock[]
  stockMovements          StockMovement[]
  stockTransfers          StockTransfer[]
  surveys                 Survey[]
  taxSettings             TaxSettings[]
  timeOffRequests         TimeOffRequest[]
  trainingModules         TrainingModule[]
  transactions            Transaction[]
  users                   User[]
  vendors                 Vendor[]
  wishlists               Wishlist[]
  WorkOrderOperation      WorkOrderOperation[]
  WorkOrder               WorkOrder[]

  @@map("tenants")
}

model User {
  id                         String               @id @default(uuid())
  tenantId                   String               @map("tenant_id")
  email                      String               @unique
  passwordHash               String               @map("password_hash")
  firstName                  String?              @map("first_name")
  lastName                   String?              @map("last_name")
  phone                      String?
  avatarUrl                  String?              @map("avatar_url")
  isActive                   Boolean              @default(true) @map("is_active")
  emailVerified              Boolean              @default(false) @map("email_verified")
  twoFactorEnabled           Boolean              @default(false) @map("two_factor_enabled")
  lastLoginAt                DateTime?            @map("last_login_at")
  createdAt                  DateTime             @default(now()) @map("created_at")
  updatedAt                  DateTime             @updatedAt @map("updated_at")
  deletedAt                  DateTime?            @map("deleted_at")
  emailVerificationExpiresAt DateTime?            @map("email_verification_expires_at")
  emailVerificationToken     String?              @map("email_verification_token")
  passwordResetExpiresAt     DateTime?            @map("password_reset_expires_at")
  passwordResetToken         String?              @map("password_reset_token")
  preferences                Json?                @default("{}")
  cannedResponses            ChatCannedResponse[]
  chatAssignments            ChatConversation[]
  chatMessages               ChatMessage[]
  reviewResponses            ReviewResponse[]
  stockMovements             StockMovement[]
  transactions               Transaction[]
  userRoles                  UserRole[]
  tenant                     Tenant               @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([email])
  @@map("users")
}

model Role {
  id              String           @id @default(uuid())
  tenantId        String           @map("tenant_id")
  name            String
  description     String?
  createdAt       DateTime         @default(now()) @map("created_at")
  rolePermissions RolePermission[]
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  userRoles       UserRole[]

  @@unique([tenantId, name])
  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  name            String           @unique
  description     String?
  createdAt       DateTime         @default(now()) @map("created_at")
  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Product {
  id                     String                   @id @default(uuid())
  tenantId               String                   @map("tenant_id")
  categoryId             String?                  @map("category_id")
  name                   String
  description            String?
  sku                    String?
  barcode                String?
  costPrice              Decimal?                 @map("cost_price") @db.Decimal(10, 2)
  sellingPrice           Decimal                  @map("selling_price") @db.Decimal(10, 2)
  taxRate                Decimal                  @default(20.00) @map("tax_rate") @db.Decimal(5, 2)
  unit                   String                   @default("pieces")
  trackInventory         Boolean                  @default(true) @map("track_inventory")
  isActive               Boolean                  @default(true) @map("is_active")
  imageUrl               String?                  @map("image_url")
  createdAt              DateTime                 @default(now()) @map("created_at")
  updatedAt              DateTime                 @updatedAt @map("updated_at")
  deletedAt              DateTime?                @map("deleted_at")
  currency               String?                  @default("EUR") @db.VarChar(3)
  BOM                    BOM[]
  BOMItem                BOMItem[]
  InspectionPlan         InspectionPlan[]
  MaterialRequirement    MaterialRequirement[]
  recommendations        ProductRecommendation[]
  reviews                ProductReview[]
  views                  ProductView[]
  ProductionCostAnalysis ProductionCostAnalysis[]
  ProductionForecast     ProductionForecast[]
  ProductionSchedule     ProductionSchedule[]
  category               Category?                @relation(fields: [categoryId], references: [id])
  tenant                 Tenant                   @relation(fields: [tenantId], references: [id])
  QCCheckpoint           QCCheckpoint[]
  stock                  Stock[]
  stockMovements         StockMovement[]
  stockTransferItems     StockTransferItem[]
  transactionItems       TransactionItem[]
  wishlistItems          WishlistItem[]
  WorkOrder              WorkOrder[]

  @@index([tenantId])
  @@index([barcode])
  @@index([sku])
  @@index([categoryId])
  @@map("products")
}

model Category {
  id        String     @id @default(uuid())
  tenantId  String     @map("tenant_id")
  parentId  String?    @map("parent_id")
  name      String
  sortOrder Int        @default(0) @map("sort_order")
  isActive  Boolean    @default(true) @map("is_active")
  createdAt DateTime   @default(now()) @map("created_at")
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  products  Product[]

  @@index([tenantId])
  @@index([parentId])
  @@map("categories")
}

model Stock {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  productId         String    @map("product_id")
  locationId        String?   @map("location_id")
  quantity          Decimal   @default(0) @db.Decimal(10, 2)
  lowStockThreshold Decimal   @default(10) @map("low_stock_threshold") @db.Decimal(10, 2)
  updatedAt         DateTime  @updatedAt @map("updated_at")
  location          Location? @relation(fields: [locationId], references: [id])
  product           Product   @relation(fields: [productId], references: [id])
  tenant            Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([productId, locationId])
  @@index([tenantId])
  @@map("stock")
}

model StockMovement {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  productId      String    @map("product_id")
  locationId     String?   @map("location_id")
  userId         String    @map("user_id")
  type           String    @map("type")
  quantity       Decimal   @db.Decimal(10, 2)
  quantityBefore Decimal   @map("quantity_before") @db.Decimal(10, 2)
  quantityAfter  Decimal   @map("quantity_after") @db.Decimal(10, 2)
  referenceType  String?   @map("reference_type")
  referenceId    String?   @map("reference_id")
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  location       Location? @relation(fields: [locationId], references: [id])
  product        Product   @relation(fields: [productId], references: [id])
  tenant         Tenant    @relation(fields: [tenantId], references: [id])
  user           User      @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([productId])
  @@index([createdAt])
  @@map("stock_movements")
}

model Transaction {
  id                String            @id @default(uuid())
  tenantId          String            @map("tenant_id")
  locationId        String?           @map("location_id")
  userId            String            @map("user_id")
  customerId        String?           @map("customer_id")
  transactionNumber String            @unique @map("transaction_number")
  status            String            @default("completed")
  subtotal          Decimal           @map("subtotal") @db.Decimal(10, 2)
  taxAmount         Decimal           @map("tax_amount") @db.Decimal(10, 2)
  discountAmount    Decimal           @default(0) @map("discount_amount") @db.Decimal(10, 2)
  total             Decimal           @db.Decimal(10, 2)
  currency          String            @default("ALL") @db.VarChar(3)
  fiscalReceiptId   String?           @map("fiscal_receipt_id")
  notes             String?
  createdAt         DateTime          @default(now()) @map("created_at")
  voidedAt          DateTime?         @map("voided_at")
  voidedBy          String?           @map("voided_by")
  payments          Payment[]
  items             TransactionItem[]
  customer          Customer?         @relation(fields: [customerId], references: [id])
  fiscalReceipt     FiscalReceipt?    @relation(fields: [fiscalReceiptId], references: [id])
  location          Location?         @relation(fields: [locationId], references: [id])
  tenant            Tenant            @relation(fields: [tenantId], references: [id])
  user              User              @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([transactionNumber])
  @@index([createdAt])
  @@index([customerId])
  @@map("transactions")
}

model TransactionItem {
  id             String      @id @default(uuid())
  transactionId  String      @map("transaction_id")
  productId      String      @map("product_id")
  productName    String      @map("product_name")
  sku            String?
  quantity       Decimal     @db.Decimal(10, 2)
  unitPrice      Decimal     @map("unit_price") @db.Decimal(10, 2)
  taxRate        Decimal     @map("tax_rate") @db.Decimal(5, 2)
  discountAmount Decimal     @default(0) @map("discount_amount") @db.Decimal(10, 2)
  subtotal       Decimal     @db.Decimal(10, 2)
  total          Decimal     @db.Decimal(10, 2)
  product        Product     @relation(fields: [productId], references: [id])
  transaction    Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([productId])
  @@map("transaction_items")
}

model Payment {
  id              String      @id @default(uuid())
  transactionId   String      @map("transaction_id")
  paymentMethod   String      @map("payment_method")
  amount          Decimal     @db.Decimal(10, 2)
  referenceNumber String?     @map("reference_number")
  createdAt       DateTime    @default(now()) @map("created_at")
  transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@map("payments")
}

model FiscalReceipt {
  id                 String        @id @default(uuid())
  tenantId           String        @map("tenant_id")
  transactionId      String        @unique @map("transaction_id")
  country            String        @default("AL")
  fiscalNumber       String?       @map("fiscal_number")
  qrCode             String?       @map("qr_code")
  submissionStatus   String        @default("pending") @map("submission_status")
  submittedAt        DateTime?     @map("submitted_at")
  responseData       Json?         @map("response_data")
  errorMessage       String?       @map("error_message")
  retryCount         Int           @default(0) @map("retry_count")
  createdAt          DateTime      @default(now()) @map("created_at")
  expiresAt          DateTime?     @map("expires_at")
  iic                String?
  qrCodeUrl          String?       @map("qr_code_url")
  verificationStatus String?       @default("unverified") @map("verification_status")
  verifiedAt         DateTime?     @map("verified_at")
  tenant             Tenant        @relation(fields: [tenantId], references: [id])
  transactions       Transaction[]

  @@index([tenantId])
  @@index([submissionStatus])
  @@index([iic])
  @@index([expiresAt])
  @@map("fiscal_receipts")
}

model Location {
  id             String          @id @default(uuid())
  tenantId       String          @map("tenant_id")
  name           String
  type           String          @default("store")
  address        String?
  city           String?
  phone          String?
  isActive       Boolean         @default(true) @map("is_active")
  createdAt      DateTime        @default(now()) @map("created_at")
  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  stock          Stock[]
  stockMovements StockMovement[]
  transfersFrom  StockTransfer[] @relation("TransfersFrom")
  transfersTo    StockTransfer[] @relation("TransfersTo")
  transactions   Transaction[]

  @@index([tenantId])
  @@map("locations")
}

model Customer {
  id                      String                   @id @default(uuid())
  tenantId                String                   @map("tenant_id")
  firstName               String?                  @map("first_name")
  lastName                String?                  @map("last_name")
  email                   String?
  phone                   String?
  birthday                DateTime?
  loyaltyPoints           Int                      @default(0) @map("loyalty_points")
  totalSpent              Decimal                  @default(0) @map("total_spent") @db.Decimal(10, 2)
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")
  abandonedCarts          AbandonedCartRecovery[]
  automationExecutions    AutomationExecution[]
  chatConversations       ChatConversation[]
  tenant                  Tenant                   @relation(fields: [tenantId], references: [id])
  emailCampaignRecipients EmailCampaignRecipient[]
  recommendations         ProductRecommendation[]
  reviews                 ProductReview[]
  productViews            ProductView[]
  referralsReceived       Referral[]               @relation("CustomerReferees")
  referralsMade           Referral[]               @relation("CustomerReferrals")
  reviewVotes             ReviewVote[]
  savedCarts              SavedCart[]
  smsCampaignRecipients   SmsCampaignRecipient[]
  surveyResponses         SurveyResponse[]
  transactions            Transaction[]
  wishlists               Wishlist[]

  @@index([tenantId])
  @@index([phone])
  @@index([email])
  @@map("customers")
}

model TaxSettings {
  id                              String    @id @default(uuid())
  tenantId                        String    @map("tenant_id")
  country                         String
  dgtUsername                     String?   @map("dgt_username")
  dgtPasswordEncrypted            String?   @map("dgt_password_encrypted")
  dgtCertificate                  String?   @map("dgt_certificate")
  dgtCertificatePasswordEncrypted String?   @map("dgt_certificate_password_encrypted")
  dgtEndpoint                     String?   @default("https://efiskalizimi-app-test.tatime.gov.al/api/") @map("dgt_endpoint")
  atkUsername                     String?   @map("atk_username")
  atkPasswordEncrypted            String?   @map("atk_password_encrypted")
  atkCertificate                  String?   @map("atk_certificate")
  atkCertificatePasswordEncrypted String?   @map("atk_certificate_password_encrypted")
  atkEndpoint                     String?   @default("https://efisc-test.atk-ks.org/api/") @map("atk_endpoint")
  certificateStatus               String?   @default("not_uploaded") @map("certificate_status")
  certificateExpiresAt            DateTime? @map("certificate_expires_at")
  lastVerifiedAt                  DateTime? @map("last_verified_at")
  integrationEnabled              Boolean   @default(false) @map("integration_enabled")
  testMode                        Boolean   @default(true) @map("test_mode")
  lastSubmissionAt                DateTime? @map("last_submission_at")
  createdAt                       DateTime  @default(now()) @map("created_at")
  updatedAt                       DateTime  @updatedAt @map("updated_at")
  tenant                          Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, country])
  @@index([tenantId])
  @@map("tax_settings")
}

model StockTransfer {
  id             String              @id @default(uuid())
  tenantId       String              @map("tenant_id")
  fromLocationId String?             @map("from_location_id")
  toLocationId   String              @map("to_location_id")
  userId         String              @map("user_id")
  transferNumber String              @unique @map("transfer_number")
  status         String              @default("pending")
  notes          String?
  createdAt      DateTime            @default(now()) @map("created_at")
  completedAt    DateTime?           @map("completed_at")
  cancelledAt    DateTime?           @map("cancelled_at")
  items          StockTransferItem[]
  fromLocation   Location?           @relation("TransfersFrom", fields: [fromLocationId], references: [id])
  tenant         Tenant              @relation(fields: [tenantId], references: [id])
  toLocation     Location            @relation("TransfersTo", fields: [toLocationId], references: [id])

  @@index([tenantId])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([createdAt])
  @@map("stock_transfers")
}

model StockTransferItem {
  id          String        @id @default(uuid())
  transferId  String        @map("transfer_id")
  productId   String        @map("product_id")
  productName String        @map("product_name")
  quantity    Decimal       @db.Decimal(10, 2)
  unit        String        @default("pieces")
  product     Product       @relation(fields: [productId], references: [id])
  transfer    StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@index([transferId])
  @@map("stock_transfer_items")
}

model AnalyticsCache {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  cacheKey   String   @map("cache_key")
  cacheType  String   @map("cache_type")
  data       Json
  validUntil DateTime @map("valid_until")
  createdAt  DateTime @default(now()) @map("created_at")
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, cacheKey])
  @@index([validUntil])
  @@map("analytics_cache")
}

model Employee {
  id                    String                @id @default(uuid())
  tenantId              String                @map("tenant_id")
  userId                String?               @map("user_id")
  firstName             String                @map("first_name")
  lastName              String                @map("last_name")
  email                 String?
  phone                 String?
  dateOfBirth           DateTime?             @map("date_of_birth")
  nationalId            String?               @map("national_id")
  address               String?
  city                  String?
  country               String                @default("AL")
  employeeNumber        String                @unique @map("employee_number")
  department            String?
  position              String?
  hireDate              DateTime              @map("hire_date")
  terminationDate       DateTime?             @map("termination_date")
  employmentType        String                @default("full_time") @map("employment_type")
  status                String                @default("active")
  salary                Float                 @default(0)
  currency              String                @default("ALL")
  payFrequency          String                @default("monthly") @map("pay_frequency")
  bankName              String?               @map("bank_name")
  bankAccountNumber     String?               @map("bank_account_number")
  taxId                 String?               @map("tax_id")
  socialSecurityNumber  String?               @map("social_security_number")
  healthInsuranceNumber String?               @map("health_insurance_number")
  emergencyContactName  String?               @map("emergency_contact_name")
  emergencyContactPhone String?               @map("emergency_contact_phone")
  avatarUrl             String?               @map("avatar_url")
  createdAt             DateTime              @default(now()) @map("created_at")
  updatedAt             DateTime              @updatedAt @map("updated_at")
  deletedAt             DateTime?             @map("deleted_at")
  documents             EmployeeDocument[]
  tenant                Tenant                @relation(fields: [tenantId], references: [id])
  expenses              Expense[]
  onboardingChecklists  OnboardingChecklist[]
  payrollRunItems       PayrollRunItem[]
  performanceReviews    PerformanceReview[]
  timeOffRequests       TimeOffRequest[]
  trainingEnrollments   TrainingEnrollment[]

  @@index([tenantId])
  @@index([employeeNumber])
  @@index([status])
  @@map("employees")
}

model EmployeePermission {
  id         String   @id @default(uuid())
  employeeId String   @map("employee_id")
  permission String
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([employeeId, permission])
  @@index([employeeId])
  @@map("employee_permissions")
}

model PayrollRun {
  id              String           @id @default(uuid())
  tenantId        String           @map("tenant_id")
  runNumber       String           @unique @map("run_number")
  periodStart     DateTime         @map("period_start")
  periodEnd       DateTime         @map("period_end")
  payDate         DateTime         @map("pay_date")
  status          String           @default("draft")
  totalGross      Decimal          @default(0) @map("total_gross") @db.Decimal(12, 2)
  totalDeductions Decimal          @default(0) @map("total_deductions") @db.Decimal(12, 2)
  totalNet        Decimal          @default(0) @map("total_net") @db.Decimal(12, 2)
  notes           String?
  approvedBy      String?          @map("approved_by")
  approvedAt      DateTime?        @map("approved_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  items           PayrollRunItem[]
  tenant          Tenant           @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([periodStart])
  @@index([status])
  @@map("payroll_runs")
}

model PayrollRunItem {
  id              String     @id @default(uuid())
  payrollRunId    String     @map("payroll_run_id")
  employeeId      String     @map("employee_id")
  baseSalary      Decimal    @default(0) @map("base_salary") @db.Decimal(10, 2)
  overtimePay     Decimal    @default(0) @map("overtime_pay") @db.Decimal(10, 2)
  bonuses         Decimal    @default(0) @db.Decimal(10, 2)
  grossPay        Decimal    @map("gross_pay") @db.Decimal(10, 2)
  incomeTax       Decimal    @default(0) @map("income_tax") @db.Decimal(10, 2)
  socialSecurity  Decimal    @default(0) @map("social_security") @db.Decimal(10, 2)
  healthInsurance Decimal    @default(0) @map("health_insurance") @db.Decimal(10, 2)
  otherDeductions Decimal    @default(0) @map("other_deductions") @db.Decimal(10, 2)
  totalDeductions Decimal    @map("total_deductions") @db.Decimal(10, 2)
  netPay          Decimal    @map("net_pay") @db.Decimal(10, 2)
  payslipUrl      String?    @map("payslip_url")
  notes           String?
  createdAt       DateTime   @default(now()) @map("created_at")
  employee        Employee   @relation(fields: [employeeId], references: [id])
  payrollRun      PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  @@index([payrollRunId])
  @@index([employeeId])
  @@map("payroll_run_items")
}

model ExpenseCategory {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  name        String
  description String?
  isActive    Boolean   @default(true) @map("is_active")
