  level         Int               @default(0)
  sequence      Int               @default(0)
  isOptional    Boolean           @default(false) @map("is_optional")
  unitCost      Decimal           @default(0) @map("unit_cost") @db.Decimal(15, 2)
  totalCost     Decimal           @default(0) @map("total_cost") @db.Decimal(15, 2)
