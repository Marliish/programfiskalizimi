  warehouse Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  bins      WarehouseBin[]

  @@unique([warehouseId, code])
  @@index([warehouseId])
  @@map("warehouse_zones")
}

model WarehouseBin {
  id          String  @id @default(uuid())
  warehouseId String  @map("warehouse_id")
  zoneId      String? @map("zone_id")

  // Location
  aisle    String?
  rack     String?
  shelf    String?
  position String?
  binCode  String  @map("bin_code")
  barcode  String? @unique

  // Properties
  binType   String   @default("standard") @map("bin_type") // standard, bulk, pallet
  maxWeight Decimal? @map("max_weight") @db.Decimal(10, 2)
  maxVolume Decimal? @map("max_volume") @db.Decimal(10, 2)

