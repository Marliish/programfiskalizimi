// ============================================
// CUSTOMER SEGMENTS
// ============================================

model CustomerSegment {
  id          String  @id @default(uuid())
  tenantId    String  @map("tenant_id")
  
  name        String
  description String?
  
  criteria      Json    @default("{}")
  customerCount Int     @default(0) @map("customer_count")
  isActive      Boolean @default(true) @map("is_active")
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  emailCampaigns EmailCampaign[]
  smsCampaigns   SmsCampaign[]
  
  @@index([tenantId])
  @@map("customer_segments")
}

// ============================================
// EMAIL CAMPAIGNS
// ============================================

model EmailCampaign {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  
  name      String
  subject   String
  fromName  String  @map("from_name")
  fromEmail String  @map("from_email")
  replyTo   String? @map("reply_to")
  
  htmlContent String? @map("html_content") @db.Text
  textContent String? @map("text_content") @db.Text
  
  // Targeting
  segmentId String? @map("segment_id")
  
  // Status
  status String @default("draft") // draft, scheduled, sending, sent, cancelled
  
  // Scheduling
  scheduledFor DateTime? @map("scheduled_for")
  sentAt       DateTime? @map("sent_at")
  
  // Stats
  totalRecipients Int @default(0) @map("total_recipients")
  sent            Int @default(0)
  delivered       Int @default(0)
  opened          Int @default(0)
  clicked         Int @default(0)
  bounced         Int @default(0)
  unsubscribed    Int @default(0)
  failed          Int @default(0)
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  tenant     Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  segment    CustomerSegment?          @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  recipients EmailCampaignRecipient[]
  
  @@index([tenantId])
  @@index([status])
  @@index([scheduledFor])
  @@map("email_campaigns")
}

model EmailCampaignRecipient {
  id         String @id @default(uuid())
  campaignId String @map("campaign_id")
  customerId String @map("customer_id")
  
  email String
  
  // Status tracking
  status    String  @default("pending") // pending, sent, delivered, opened, clicked, bounced, failed
  messageId String? @map("message_id")
  
  // Engagement
  openedAt  DateTime? @map("opened_at")
  clickedAt DateTime? @map("clicked_at")
  bouncedAt DateTime? @map("bounced_at")
  errorMessage String? @map("error_message") @db.Text
  
  sentAt    DateTime? @map("sent_at")
  createdAt DateTime  @default(now()) @map("created_at")
  
  // Relations
  campaign EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  @@index([campaignId])
  @@index([customerId])
  @@index([status])
  @@map("email_campaign_recipients")
}

model EmailTemplate {
  id          String  @id @default(uuid())
  tenantId    String  @map("tenant_id")
  
  name            String
  description     String?
  subjectTemplate String? @map("subject_template")
  htmlTemplate    String? @map("html_template") @db.Text
  textTemplate    String? @map("text_template") @db.Text
  
  // Variables (JSON array)
  variables Json @default("[]")
  
  category String? // welcome, receipt, marketing, transactional
  isActive Boolean @default(true) @map("is_active")
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@index([tenantId])
  @@map("email_templates")
}

// ============================================
// SMS CAMPAIGNS
// ============================================

model SmsCampaign {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  
  name    String
  message String @db.Text
  
  // Targeting
  segmentId String? @map("segment_id")
  
  // Status
  status String @default("draft") // draft, scheduled, sending, sent, cancelled
  
  // Scheduling
  scheduledFor DateTime? @map("scheduled_for")
  sentAt       DateTime? @map("sent_at")
  
  // Stats
  totalRecipients Int @default(0) @map("total_recipients")
  sent            Int @default(0)
  delivered       Int @default(0)
  failed          Int @default(0)
  optedOut        Int @default(0) @map("opted_out")
  
  // Cost tracking
  costPerSms Decimal? @map("cost_per_sms") @db.Decimal(10, 4)
  totalCost  Decimal? @map("total_cost") @db.Decimal(10, 2)
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  tenant     Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  segment    CustomerSegment?        @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  recipients SmsCampaignRecipient[]
  
  @@index([tenantId])
  @@index([status])
  @@index([scheduledFor])
  @@map("sms_campaigns")
}

model SmsCampaignRecipient {
  id         String @id @default(uuid())
  campaignId String @map("campaign_id")
  customerId String @map("customer_id")
  
  phone String
  
  // Status tracking
  status     String  @default("pending") // pending, sent, delivered, failed, opted_out
  messageSid String? @map("message_sid")
  
  errorMessage String?   @map("error_message") @db.Text
  deliveredAt  DateTime? @map("delivered_at")
  sentAt       DateTime? @map("sent_at")
  
  createdAt DateTime @default(now()) @map("created_at")
  
  // Relations
  campaign SmsCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  @@index([campaignId])
  @@index([customerId])
  @@map("sms_campaign_recipients")
}

// ============================================
// CUSTOMER SURVEYS
// ============================================

model Survey {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  
  title       String
  description String? @db.Text
  
  // Distribution
  distributionMethod String? @map("distribution_method") // email, sms, in_app, link
  
  // Status
  status String @default("draft") // draft, active, closed
  
  // Dates
  startsAt DateTime? @map("starts_at")
  endsAt   DateTime? @map("ends_at")
  
  // Stats
  totalSent      Int @default(0) @map("total_sent")
  totalResponses Int @default(0) @map("total_responses")
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  questions SurveyQuestion[]
  responses SurveyResponse[]
  
  @@index([tenantId])
  @@index([status])
  @@map("surveys")
}

model SurveyQuestion {
  id       String @id @default(uuid())
  surveyId String @map("survey_id")
  
  question     String @db.Text
  questionType String @map("question_type") // text, multiple_choice, rating, yes_no, nps
  
  // Options for multiple choice (JSON array)
  options Json @default("[]")
  
  required  Boolean @default(false)
  sortOrder Int     @default(0) @map("sort_order")
  
  createdAt DateTime @default(now()) @map("created_at")
  
  // Relations
  survey  Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  answers SurveyAnswer[]
  
  @@index([surveyId])
  @@map("survey_questions")
}

model SurveyResponse {
  id         String  @id @default(uuid())
  surveyId   String  @map("survey_id")
  customerId String? @map("customer_id")
  
  isAnonymous Boolean @default(false) @map("is_anonymous")
  
  // Metadata
  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent") @db.Text
  
  completedAt DateTime @default(now()) @map("completed_at")
  createdAt   DateTime @default(now()) @map("created_at")
  
  // Relations
  survey   Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  customer Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  answers  SurveyAnswer[]
  
  @@index([surveyId])
  @@index([customerId])
  @@map("survey_responses")
}

model SurveyAnswer {
  id         String @id @default(uuid())
  responseId String @map("response_id")
  questionId String @map("question_id")
  
  answer String @db.Text
  
  createdAt DateTime @default(now()) @map("created_at")
  
  // Relations
  response SurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  
  @@index([responseId])
  @@index([questionId])
  @@map("survey_answers")
}

// ============================================
// REFERRAL PROGRAM
// ============================================

model ReferralProgram {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  
  name        String
  description String? @db.Text
  
  // Rewards
  referrerRewardType   String  @map("referrer_reward_type") // points, discount, cash
  referrerRewardAmount Decimal @map("referrer_reward_amount") @db.Decimal(10, 2)
  
  refereeRewardType   String  @map("referee_reward_type")
  refereeRewardAmount Decimal @map("referee_reward_amount") @db.Decimal(10, 2)
  
  // Conditions
  minPurchaseAmount Decimal @default(0) @map("min_purchase_amount") @db.Decimal(10, 2)
  
  // Status
  isActive Boolean   @default(true) @map("is_active")
  startsAt DateTime? @map("starts_at")
  endsAt   DateTime? @map("ends_at")
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  referrals Referral[]
  
  @@index([tenantId])
  @@map("referral_programs")
}

model Referral {
  id        String @id @default(uuid())
  programId String @map("program_id")
  
  // Referrer (customer making the referral)
  referrerCustomerId String @map("referrer_customer_id")
  
  // Referee (new customer)
  refereeCustomerId String? @map("referee_customer_id")
  
  referralCode String @unique @map("referral_code")
  
  // Tracking
  clicks Int    @default(0)
  status String @default("pending") // pending, completed, expired
  
  // Completion
  completedAt    DateTime? @map("completed_at")
  purchaseAmount Decimal?  @map("purchase_amount") @db.Decimal(10, 2)
  
  // Rewards
  referrerRewardGiven Boolean @default(false) @map("referrer_reward_given")
  refereeRewardGiven  Boolean @default(false) @map("referee_reward_given")
  
  createdAt DateTime  @default(now()) @map("created_at")
  expiresAt DateTime? @map("expires_at")
  
  // Relations
  program          ReferralProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  referrerCustomer Customer        @relation("CustomerReferrals", fields: [referrerCustomerId], references: [id], onDelete: Cascade)
  refereeCustomer  Customer?       @relation("CustomerReferees", fields: [refereeCustomerId], references: [id], onDelete: SetNull)
  
  @@index([programId])
  @@index([referrerCustomerId])
  @@index([referralCode])
  @@map("referrals")
}

// ============================================
// SOCIAL MEDIA
// ============================================

model SocialPost {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  
  platform String // facebook, instagram, twitter
  content  String @db.Text
  
  // Media (JSON array of URLs)
  mediaUrls Json @default("[]") @map("media_urls")
  
  // Status
  status String @default("draft") // draft, scheduled, published, failed
  
  // Scheduling
  scheduledFor DateTime? @map("scheduled_for")
  publishedAt  DateTime? @map("published_at")
  
  // External IDs
  platformPostId String? @map("platform_post_id")
  
  // Stats
  likes          Int     @default(0)
  shares         Int     @default(0)
  comments       Int     @default(0)
  impressions    Int     @default(0)
  engagementRate Decimal @default(0) @map("engagement_rate") @db.Decimal(5, 2)
  
  errorMessage String? @map("error_message") @db.Text
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@index([tenantId])
  @@index([platform])
  @@index([status])
  @@index([scheduledFor])
  @@map("social_posts")
}

model SocialReview {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  
  platform String // google, facebook, yelp
  
  reviewerName       String? @map("reviewer_name")
  reviewerProfileUrl String? @map("reviewer_profile_url")
  
  rating     Int     @map("rating") // 1-5
  reviewText String? @map("review_text") @db.Text
  
  // Response
  responded    Boolean   @default(false)
  responseText String?   @map("response_text") @db.Text
  respondedAt  DateTime? @map("responded_at")
  
  // Metadata
  reviewDate       DateTime? @map("review_date")
  platformReviewId String?   @map("platform_review_id")
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@index([tenantId])
  @@index([platform])
  @@index([rating])
  @@index([responded])
  @@map("social_reviews")
}

model SocialAccount {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  
  platform      String // facebook, instagram, twitter
  accountName   String? @map("account_name")
  accountHandle String? @map("account_handle")
  
  // OAuth tokens (encrypted)
  accessTokenEncrypted  String?   @map("access_token_encrypted") @db.Text
  refreshTokenEncrypted String?   @map("refresh_token_encrypted") @db.Text
  tokenExpiresAt        DateTime? @map("token_expires_at")
  
  isActive Boolean @default(true) @map("is_active")
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@unique([tenantId, platform])
  @@index([tenantId])
  @@map("social_accounts")
}

// ============================================
// MARKETING AUTOMATION
// ============================================

model AutomationWorkflow {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  
  name        String
  description String? @db.Text
  
  // Trigger
  triggerType       String @map("trigger_type") // customer_signup, purchase, abandoned_cart, birthday
  triggerConditions Json   @default("{}") @map("trigger_conditions")
  
  // Actions (JSON array)
  actions Json @default("[]")
  
  isActive Boolean @default(true) @map("is_active")
  
  // Stats
  triggeredCount Int @default(0) @map("triggered_count")
  completedCount Int @default(0) @map("completed_count")
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Relations
  tenant     Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  executions AutomationExecution[]
  
  @@index([tenantId])
  @@index([triggerType])
  @@map("automation_workflows")
}

model AutomationExecution {
  id         String  @id @default(uuid())
  workflowId String  @map("workflow_id")
  customerId String? @map("customer_id")
  
  status String @default("running") // running, completed, failed
  
  triggerData  Json?   @map("trigger_data")
  errorMessage String? @map("error_message") @db.Text
  
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  
  // Relations
  workflow AutomationWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  customer Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  
  @@index([workflowId])
  @@map("automation_executions")
}

