# =============================================================================
# FISCALNEXT - ENVIRONMENT VARIABLES TEMPLATE
# Created by: Max (DevOps Engineer)
# Date: 2026-02-23
# =============================================================================
# 
# INSTRUCTIONS:
# 1. Copy this file to .env for local development
# 2. For staging/production, use CI/CD secrets or server-specific .env files
# 3. NEVER commit .env files to git
# 4. Update values according to your environment
#
# =============================================================================

# -----------------------------------------------------------------------------
# ENVIRONMENT
# -----------------------------------------------------------------------------
NODE_ENV=development                    # development | staging | production
ENVIRONMENT_NAME=local                  # local | staging | production

# -----------------------------------------------------------------------------
# API SERVER CONFIGURATION
# -----------------------------------------------------------------------------
API_PORT=5000
API_HOST=0.0.0.0
BASE_URL=http://localhost:5000

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost                 # localhost | postgres (Docker) | IP address
POSTGRES_PORT=5432
POSTGRES_DB=fiscalnext_dev
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123              # CHANGE IN PRODUCTION!

# Full connection string (alternative to individual vars)
DATABASE_URL=postgresql://admin:admin123@localhost:5432/fiscalnext_dev?schema=public

# Connection pool settings
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=10000

# -----------------------------------------------------------------------------
# REDIS CACHE
# -----------------------------------------------------------------------------
REDIS_HOST=localhost                    # localhost | redis (Docker) | IP address
REDIS_PORT=6379
REDIS_PASSWORD=                         # Empty for local, set for staging/production
REDIS_DB=0

# Full connection string (alternative to individual vars)
REDIS_URL=redis://localhost:6379

# Redis TTL (in seconds)
CACHE_TTL_DEFAULT=3600                  # 1 hour
CACHE_TTL_SESSION=86400                 # 24 hours
CACHE_TTL_SHORT=300                     # 5 minutes

# -----------------------------------------------------------------------------
# RABBITMQ MESSAGE QUEUE
# -----------------------------------------------------------------------------
RABBITMQ_HOST=localhost                 # localhost | rabbitmq (Docker) | IP address
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin123              # CHANGE IN PRODUCTION!
RABBITMQ_VHOST=/

# Full connection string
RABBITMQ_URL=amqp://admin:admin123@localhost:5672

# -----------------------------------------------------------------------------
# AUTHENTICATION & SECURITY
# -----------------------------------------------------------------------------
# JWT Settings
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-use-at-least-32-chars
JWT_EXPIRES_IN=24h                      # 24 hours
JWT_REFRESH_EXPIRES_IN=7d               # 7 days

# Bcrypt rounds (10-12 recommended, higher = more secure but slower)
BCRYPT_ROUNDS=10

# Session settings
SESSION_SECRET=your-session-secret-change-this
SESSION_MAX_AGE=86400000                # 24 hours in milliseconds

# Rate limiting
RATE_LIMIT_WINDOW=60000                 # 1 minute in milliseconds
RATE_LIMIT_MAX_REQUESTS=100             # Max requests per window

# -----------------------------------------------------------------------------
# CORS SETTINGS
# -----------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true

# -----------------------------------------------------------------------------
# FRONTEND APPLICATIONS
# -----------------------------------------------------------------------------
# Web Admin
WEB_ADMIN_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_APP_NAME=FiscalNext Admin
NEXT_PUBLIC_APP_VERSION=0.1.0

# Web POS
WEB_POS_PORT=3001
NEXT_PUBLIC_POS_API_URL=http://localhost:5000
NEXT_PUBLIC_POS_APP_NAME=FiscalNext POS

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=debug                         # debug | info | warn | error
LOG_FORMAT=json                         # json | pretty
LOG_FILE_ENABLED=false                  # true | false
LOG_FILE_PATH=./logs/app.log

# -----------------------------------------------------------------------------
# FILE STORAGE
# -----------------------------------------------------------------------------
STORAGE_TYPE=local                      # local | s3 | azure
UPLOAD_MAX_SIZE=10485760                # 10MB in bytes
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,application/pdf

# Local storage
STORAGE_LOCAL_PATH=./uploads

# AWS S3 (if using S3)
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=fiscalnext-uploads

# -----------------------------------------------------------------------------
# EMAIL SERVICE
# -----------------------------------------------------------------------------
EMAIL_ENABLED=false                     # true | false
EMAIL_PROVIDER=smtp                     # smtp | sendgrid | mailgun

# SMTP Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false                       # true for port 465, false for other ports
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@fiscalnext.com
SMTP_FROM_NAME=FiscalNext

# SendGrid (alternative)
SENDGRID_API_KEY=

# -----------------------------------------------------------------------------
# PAYMENT PROVIDERS
# -----------------------------------------------------------------------------
# Stripe
STRIPE_ENABLED=false
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PayPal
PAYPAL_ENABLED=false
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_MODE=sandbox                     # sandbox | live

# -----------------------------------------------------------------------------
# FISCALIZATION APIs (Albania & Kosovo)
# -----------------------------------------------------------------------------
# Albania Tax Authority
ALBANIA_TAX_API_URL=https://efiscal.tatime.gov.al/FISCALSERVICES
ALBANIA_TAX_API_KEY=
ALBANIA_TAX_COMPANY_ID=
ALBANIA_TAX_CERTIFICATE_PATH=./certs/albania.p12
ALBANIA_TAX_CERTIFICATE_PASSWORD=

# Kosovo Tax Authority  
KOSOVO_TAX_API_URL=https://efiskalizimi-app.atk-ks.org/api
KOSOVO_TAX_API_KEY=
KOSOVO_TAX_COMPANY_ID=
KOSOVO_TAX_CERTIFICATE_PATH=./certs/kosovo.p12
KOSOVO_TAX_CERTIFICATE_PASSWORD=

# -----------------------------------------------------------------------------
# MONITORING & ANALYTICS
# -----------------------------------------------------------------------------
# Sentry Error Tracking
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1           # 10% of transactions

# Google Analytics
GA_TRACKING_ID=

# Application Insights (Azure)
APPINSIGHTS_INSTRUMENTATIONKEY=

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
FEATURE_MOBILE_APP=false
FEATURE_INVENTORY=true
FEATURE_REPORTING=true
FEATURE_MULTI_CURRENCY=false
FEATURE_OFFLINE_MODE=true

# -----------------------------------------------------------------------------
# DEVELOPMENT TOOLS
# -----------------------------------------------------------------------------
# Hot Reload
HOT_RELOAD=true

# Debug mode
DEBUG=false

# Seed database on startup (development only!)
DB_SEED_ON_START=false

# Mock external APIs (development/testing)
MOCK_EXTERNAL_APIS=false

# -----------------------------------------------------------------------------
# DOCKER CONFIGURATION
# -----------------------------------------------------------------------------
DOCKER_REGISTRY=fiscalnext              # Docker registry name
IMAGE_TAG=latest                        # Docker image tag

# -----------------------------------------------------------------------------
# BACKUP & MAINTENANCE
# -----------------------------------------------------------------------------
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *               # Cron: Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/backups

# -----------------------------------------------------------------------------
# MONITORING (Prometheus/Grafana)
# -----------------------------------------------------------------------------
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090
GRAFANA_PASSWORD=admin                  # CHANGE IN PRODUCTION!

# -----------------------------------------------------------------------------
# SSL/TLS CERTIFICATES
# -----------------------------------------------------------------------------
SSL_ENABLED=false
SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem
SSL_KEY_PATH=/etc/nginx/ssl/privkey.pem

# =============================================================================
# END OF CONFIGURATION
# =============================================================================
