# Server Configuration
NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# Database
DATABASE_URL="postgresql://admin:admin123@localhost:5432/fiscalnext_dev?schema=public"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this

# CORS
