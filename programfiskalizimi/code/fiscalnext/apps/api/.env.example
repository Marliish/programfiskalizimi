# API Configuration
NODE_ENV=development
API_PORT=5000
API_HOST=0.0.0.0

# Database
DATABASE_URL="postgresql://fiscalnext:fiscalnext_dev_password@localhost:5432/fiscalnext_dev?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# RabbitMQ
RABBITMQ_URL="amqp://fiscalnext:fiscalnext_dev_password@localhost:5672"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# CORS
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# Fiscal APIs
ALBANIA_FISCAL_API_URL=""
ALBANIA_FISCAL_API_KEY=""
KOSOVO_FISCAL_API_URL=""
KOSOVO_FISCAL_API_KEY=""

# Email
SENDGRID_API_KEY=""
FROM_EMAIL="noreply@fiscalnext.com"

# SMS
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# S3/Spaces
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET=""
S3_REGION="nyc3"
S3_ENDPOINT=""

# Sentry
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
