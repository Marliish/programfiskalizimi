# Environment Configuration
NODE_ENV=development

# Database
DATABASE_URL="postgresql://fiscalnext:fiscalnext_dev_password@localhost:5432/fiscalnext_dev?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# RabbitMQ
RABBITMQ_URL="amqp://fiscalnext:fiscalnext_dev_password@localhost:5672"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# API
API_PORT=5000
API_HOST=localhost

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:5000"

# Email (SendGrid)
SENDGRID_API_KEY=""
FROM_EMAIL="noreply@fiscalnext.com"

# SMS (Twilio)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# File Storage (S3 / DigitalOcean Spaces)
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET=""
S3_REGION="nyc3"
S3_ENDPOINT="https://nyc3.digitaloceanspaces.com"

# Error Tracking (Sentry)
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"

# Albania Fiscal API
ALBANIA_FISCAL_API_URL="https://efiskalizimi-app.tatime.gov.al"
ALBANIA_FISCAL_API_KEY=""

# Kosovo Fiscal API
KOSOVO_FISCAL_API_URL="https://etks.rks-gov.net"
KOSOVO_FISCAL_API_KEY=""

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000  # 1 minute
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# Logging
LOG_LEVEL=info
